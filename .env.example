# ── PALYMORF ENVIRONMENT VARIABLES ──────────────
# Copy this file to .env.local for local development
# Add these same variables in Vercel → Project → Settings → Environment Variables

# ── SUPABASE ─────────────────────────────────────
# Found in Supabase → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── RESEND (email notifications) ─────────────────
# Found in resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

# ── NOTIFICATIONS ─────────────────────────────────
# Email address(es) to notify on new submission
# For multiple: sean@palymorf.com,wanda@palymorf.com
NOTIFY_EMAIL=sean@palymorf.com,wanda@palymorf.com

# ── ADMIN DASHBOARD ───────────────────────────────
# Password to access /admin — change this to something strong
ADMIN_PASSWORD=palymorf2026
